<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday Ayushi! 🎀</title>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Great+Vibes&family=Poppins:wght@400;600&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }

        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 40%, #fbc2eb 70%, #a18cd1 100%);
            background-size: 200% 200%;
            animation: gradientBG 10s ease infinite;
            font-family: 'Poppins', sans-serif;
            overflow: hidden;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Floating Sparkles */
        .floating-item {
            position: absolute;
            font-size: 30px;
            color: rgba(255, 255, 255, 0.7);
            animation: float linear infinite;
            z-index: 1;
            filter: drop-shadow(0 0 8px rgba(255,105,180,0.6));
        }

        @keyframes float {
            0% { transform: translateY(100vh) scale(0.5) rotate(0deg); opacity: 1; }
            100% { transform: translateY(-10vh) scale(1.2) rotate(360deg); opacity: 0; }
        }

        /* Glassmorphism Container */
        .container {
            background: rgba(255, 255, 255, 0.7);
            padding: 40px 30px;
            border-radius: 30px;
            box-shadow: 0 15px 35px rgba(255, 105, 180, 0.25), inset 0 0 15px rgba(255, 255, 255, 0.6);
            text-align: center;
            max-width: 450px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            z-index: 10;
            border: 2px solid rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(15px);
            transition: all 0.5s ease;
            display: none; /* Hidden by default */
        }

        /* Scrollbar for overflow */
        .container::-webkit-scrollbar { width: 6px; }
        .container::-webkit-scrollbar-thumb { background: #ff99ac; border-radius: 10px; }

        #login-screen { display: block; } /* First screen to show */

        h1 {
            font-family: 'Dancing Script', cursive;
            color: #ff3377;
            font-size: 2.8em;
            margin-top: 0;
            margin-bottom: 5px;
            text-shadow: 2px 2px 4px rgba(255, 105, 180, 0.3);
            animation: pulse 2s infinite;
        }

        .cursive-title { font-family: 'Great Vibes', cursive; font-size: 3.5em; color: #d14777; }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .hint {
            color: #c94b82;
            font-size: 0.95em;
            margin-bottom: 20px;
            font-style: italic;
            line-height: 1.5;
            font-weight: 600;
        }

        /* Inputs and Buttons */
        input[type="text"] {
            width: 85%;
            padding: 15px;
            border: 3px solid #ffb6c1;
            border-radius: 25px;
            font-size: 1.1em;
            font-family: 'Poppins', sans-serif;
            color: #ff3377;
            text-align: center;
            outline: none;
            transition: all 0.3s ease;
            background: rgba(255, 250, 250, 0.9);
        }

        input[type="text"]:focus {
            border-color: #ff69b4;
            box-shadow: 0 0 15px rgba(255, 105, 180, 0.5);
            transform: scale(1.02);
        }

        .btn-group { display: flex; justify-content: center; gap: 15px; margin-top: 20px; flex-wrap: wrap; }

        button, .download-btn {
            background: linear-gradient(45deg, #ff6a88 0%, #ff99ac 100%);
            color: white;
            border: none;
            padding: 12px 25px;
            font-size: 1.1em;
            border-radius: 25px;
            cursor: pointer;
            font-family: 'Poppins', sans-serif;
            font-weight: 600;
            box-shadow: 0 8px 20px rgba(255, 105, 136, 0.4);
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        button:hover, .download-btn:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 12px 25px rgba(255, 105, 136, 0.6);
        }

        .secondary-btn { background: linear-gradient(45deg, #e0c3fc 0%, #8ec5fc 100%); box-shadow: 0 8px 20px rgba(142, 197, 252, 0.4); }
        .secondary-btn:hover { box-shadow: 0 12px 25px rgba(142, 197, 252, 0.6); }

        /* Quiz Styles */
        .timer {
            font-size: 1.5em; color: #ff3377; font-weight: bold; margin-bottom: 15px;
            background: rgba(255, 255, 255, 0.8); display: inline-block; padding: 5px 20px;
            border-radius: 20px; border: 2px dashed #ff99ac;
        }
        .option-btn {
            display: block; width: 100%; margin: 10px 0; background: rgba(255, 255, 255, 0.9);
            color: #d14777; border: 2px solid #ffb6c1; padding: 12px; border-radius: 15px;
            font-size: 1em; text-align: left; box-shadow: 0 4px 10px rgba(255, 105, 180, 0.1);
        }
        .option-btn:hover { background: #ffe6f2; border-color: #ff69b4; transform: scale(1.02); }

        /* Images and Messages */
        .memory-img, .media-content {
            width: 100%; max-width: 250px; border-radius: 20px; border: 5px solid white;
            box-shadow: 0 10px 20px rgba(255, 105, 180, 0.3); margin-bottom: 15px;
        }
        
        .memory-img { transform: rotate(-3deg); transition: transform 0.3s; }
        .memory-img:hover { transform: rotate(0deg) scale(1.05); }

        .letter-text {
            font-size: 1.05em; color: #5a3d5c; line-height: 1.6; text-align: left;
            background: rgba(255, 255, 255, 0.6); padding: 20px; border-radius: 15px;
            border-left: 4px solid #ff99ac; margin-bottom: 20px;
        }

        .social-box {
            background: white; padding: 15px; border-radius: 15px; margin: 10px 0;
            color: #d14777; font-weight: bold; display: flex; align-items: center; justify-content: center; gap: 10px;
            box-shadow: 0 5px 15px rgba(255,105,180,0.15); border: 1px solid #ffe6f2;
        }

        /* Music Player */
        #music-player {
            position: fixed; bottom: 20px; right: 20px; background: rgba(255, 255, 255, 0.9);
            padding: 10px 20px; border-radius: 30px; box-shadow: 0 5px 15px rgba(255, 105, 180, 0.3);
            display: none; z-index: 100; align-items: center; gap: 10px; border: 2px solid #ffb6c1;
            color: #ff3377; font-weight: 600;
        }
        .music-btn { background: none; border: none; font-size: 1.5em; padding: 0; box-shadow: none; cursor: pointer; }
        
        .shake { animation: shake 0.4s cubic-bezier(.36,.07,.19,.97) both; }
        @keyframes shake {
            10%, 90% { transform: translate3d(-5px, 0, 0); }
            20%, 80% { transform: translate3d(5px, 0, 0); }
            30%, 50%, 70% { transform: translate3d(-10px, 0, 0); }
            40%, 60% { transform: translate3d(10px, 0, 0); }
        }
    </style>
</head>
<body>

    <!-- Only ONE continuous song now! -->
    <audio id="song1" src="song1.mp3" loop></audio>
    
    <script>
        const emojis = ['🌸', '✨', '💖', '🎀', '🦋', '🍡', '💌'];
        for(let i=0; i<15; i++) {
            let div = document.createElement('div');
            div.className = 'floating-item';
            div.innerText = emojis[Math.floor(Math.random() * emojis.length)];
            div.style.left = Math.random() * 100 + 'vw';
            div.style.animationDuration = (Math.random() * 5 + 4) + 's';
            div.style.animationDelay = (Math.random() * 5) + 's';
            document.body.appendChild(div);
        }
    </script>

    <div id="music-player">
        <span>🎶 Vibe Check</span>
        <button class="music-btn" onclick="toggleMusic()" id="play-pause-btn">⏸️</button>
    </div>

    <div class="container" id="login-screen">
        <h1>Hey Dumbo! 🎀</h1>
        <p class="hint">Hint: This is that special day which made all this come true.. ✨</p>
        <input type="text" id="passwordInput" placeholder="DD/MM/YYYY">
        <div class="btn-group"><button onclick="checkPassword()">Unlock 💌</button></div>
        <p id="status-msg" style="color: #ff3377; margin-top: 15px; font-weight: 600;">You have 5 chances left! 💕</p>
    </div>

    <div class="container" id="deleted-screen" style="background: rgba(0,0,0,0.8);">
        <h1 style="color: #d32f2f; font-family: monospace;">ERROR 💔</h1>
        <p class="hint" style="color: #ff6666;">Oops... all data deleted!</p>
    </div>

    <div class="container" id="popup-screen">
        <h1 id="popup-title">Happy Birthday Ayushi! 🎉</h1>
        <p class="hint" id="popup-text">Click yes to continue further 💖</p>
        <div class="btn-group" id="popup-buttons">
            <button onclick="handleYes()">Yes 🌸</button>
            <button onclick="handleNo()" class="secondary-btn">No 🙈</button>
        </div>
    </div>

    <div class="container" id="quiz-intro-screen">
        <h1>Heyyy! 🌸</h1>
        <p class="hint" style="font-size: 1.1em; color: #ff3377;">Answer each question to see a hidden surprise! The last one is VERY special, so good luck! 🍀✨</p>
        <button onclick="showEarphones()">Let's go! 💕</button>
    </div>

    <div class="container" id="earphones-screen">
        <h1>Wait! 🎧</h1>
        <p class="hint" style="font-size: 1.2em;">Please put your earphones on for the best experience! Trust me! 😉</p>
        <button onclick="startQuiz()">I'm wearing them! 🎶</button>
    </div>

    <div class="container" id="quiz-screen">
        <div class="timer" id="timer-display">⏱️ 60s</div>
        <h2 id="question-text" style="color: #ff3377;">Question</h2>
        <div id="options-container"></div>
        <p id="quiz-feedback" style="color: #ff3377; font-weight: 600; display: none; margin-top: 10px;">Oops! Try again! 🥺</p>
    </div>

    <div class="container" id="continue-popup">
        <h1>Yay! Correct! 🎉</h1>
        <p class="hint">You did it! Ready for the next one?</p>
        <button onclick="nextQuestion()">Continue further 🌸</button>
    </div>

    <!-- NEW: Video or GIF popup for Question 2 -->
    <div class="container" id="media-popup-screen">
        <h1>Correct! ✨</h1>
        <p class="hint">Look at this little memory... 💖</p>
        
        <!-- To use a VIDEO, keep this section: -->
        <video class="media-content" controls autoplay>
            <source src="your-video.mp4" type="video/mp4">
            Your browser does not support the video tag.
        </video>
        
        <!-- To use a GIF INSTEAD, delete the <video> block above and uncomment this line: -->
        <!-- <img src="your-gif.gif" alt="Cute Memory" class="media-content"> -->

        <div class="btn-group">
            <button onclick="nextQuestion()">Continue further 🎀</button>
        </div>
    </div>

    <div class="container" id="image-popup-screen">
        <h1>Surprise! 📸</h1>
        <p class="hint">A little memory unlocked just for you!</p>
        <img id="dynamic-image" src="" alt="Memory" class="memory-img">
        <div class="btn-group">
            <a id="download-link" href="" download class="download-btn">Download 📥</a>
            <button onclick="handleImageContinue()" class="secondary-btn">Continue 🌸</button>
        </div>
    </div>

    <div class="container" id="message-screen">
        <h1 class="cursive-title">To my lifesaver...</h1>
        <div class="letter-text">
            Dear Ayushi,<br><br>
            If our lives were a Kdrama, you would definitely be the brilliant, beautiful main character who somehow manages to save my grades and my sanity every single time. 😂✨<br><br>
            Thank you for being the absolute best friend anyone could ask for. Your endless help with my academics means the world to me, but mostly, I'm just so lucky to have you in my life.<br><br>
            Wishing you a birthday as amazing, cute, and perfect as you are! Keep shining! 💖
        </div>
        <button onclick="showSocials()">Continue further 🎀</button>
    </div>

    <div class="container" id="socials-screen">
        <h1>Stay in touch! 💌</h1>
        <p class="hint">Always here for you, anytime!</p>
        
        <div class="social-box">📱 WhatsApp: +919232140986</div>
        <div class="social-box">📸 Instagram: just_uncaffeinated</div>
        <div class="social-box">📸 Instagram password: laksya ko harane wala</div>
        <div class="social-box">👻 discord: Venky_ykneV</div>
        <div class="social-box">👻 discord password: shaurya_pathak</div>

        <div class="btn-group">
            <button onclick="showFinal()">Finish 🎬</button>
        </div>
    </div>

    <div class="container" id="final-screen">
        <h1 class="cursive-title" style="font-size: 4em;">Thank You!</h1>
        <h2 style="color: #ff3377; font-family: 'Poppins';">And a very Happy Birthday Ayushi! 🎂🌸✨</h2>
        <p class="hint">I hope you loved this little surprise. Enjoy your special day!</p>
    </div>

    <script>
        // --- LOGIC ---
        let attempts = 5;
        const correctDate = "31/12/2025"; 

        function hideAll() { document.querySelectorAll('.container').forEach(c => c.style.display = 'none'); }

        // Login Logic
        function checkPassword() {
            const input = document.getElementById('passwordInput').value.trim();
            if (input === correctDate) {
                hideAll(); document.getElementById('popup-screen').style.display = 'block';
            } else {
                attempts--;
                const ls = document.getElementById('login-screen');
                ls.classList.remove('shake'); void ls.offsetWidth; ls.classList.add('shake');
                if (attempts > 0) {
                    document.getElementById('status-msg').innerText = `Oopsie! Wrong date. You have ${attempts} chance(s) left! 🥺`;
                } else {
                    hideAll(); document.getElementById('deleted-screen').style.display = 'block';
                }
            }
        }

        // Dialogues
        let yesCount = 0;
        function handleYes() {
            if (yesCount === 0) {
                document.getElementById('popup-title').innerText = "Are you sure? 🤔";
                document.getElementById('popup-text').innerText = "There is no turning back now...";
                yesCount++;
            } else {
                hideAll(); document.getElementById('quiz-intro-screen').style.display = 'block';
            }
        }
        function handleNo() {
            document.getElementById('popup-title').innerText = "Whatever! 💅";
            document.getElementById('popup-text').innerText = "I don't care, see what I have made anyway!";
            document.getElementById('popup-buttons').style.display = 'none';
            setTimeout(() => { hideAll(); document.getElementById('quiz-intro-screen').style.display = 'block'; }, 2500);
        }

        function showEarphones() { hideAll(); document.getElementById('earphones-screen').style.display = 'block'; }

        // Audio Logic
        let currentAudio = null;
        const song1 = document.getElementById('song1');

        function playAudio(audio) {
            // If the song is already playing, don't restart it!
            if (currentAudio === audio) return; 
            
            if(currentAudio) { currentAudio.pause(); currentAudio.currentTime = 0; }
            currentAudio = audio;
            currentAudio.play().catch(e => console.log("Audio needs interaction"));
            document.getElementById('music-player').style.display = 'flex';
            document.getElementById('play-pause-btn').innerText = '⏸️';
        }

        function toggleMusic() {
            if(currentAudio.paused) { currentAudio.play(); document.getElementById('play-pause-btn').innerText = '⏸️'; } 
            else { currentAudio.pause(); document.getElementById('play-pause-btn').innerText = '▶️'; }
        }

        // Quiz Logic
        const questions = [
            { subject: "Biology 🧬", text: "What is known as the powerhouse of the cell?", options: ["Nucleus", "Mitochondria", "Ribosome", "Chloroplast"], answer: 1 },
            { subject: "Chemistry 🧪", text: "What is the chemical formula for water?", options: ["H2O", "CO2", "NaCl", "O2"], answer: 0 },
            { subject: "Physics 🔭", text: "What invisible force keeps us grounded on Earth?", options: ["Magnetism", "Friction", "Gravity", "Magic"], answer: 2 },
            { subject: "Mathematics 📐", text: "What is the value of Pi to two decimal places?", options: ["3.12", "3.16", "3.14", "3.18"], answer: 2 },
            { subject: "The Ultimate Question 👑", text: "Who is the smartest, most amazing bestie ever?", options: ["Batman", "Gojo Satoru", "Iron Man", "Ayushi ✨"], answer: 3 }
        ];

        let currentQuestionIndex = 0;
        let timerInterval;
        let timeLeft = 60;

        function startQuiz() { currentQuestionIndex = 0; loadQuestion(); }

        function loadQuestion() {
            hideAll();
            const q = questions[currentQuestionIndex];
            document.getElementById('question-text').innerText = `${q.subject}\n${q.text}`;
            document.getElementById('quiz-feedback').style.display = 'none';
            
            const optionsContainer = document.getElementById('options-container');
            optionsContainer.innerHTML = '';
            q.options.forEach((opt, index) => {
                const btn = document.createElement('button'); btn.className = 'option-btn';
                btn.innerText = opt; btn.onclick = () => checkAnswer(index);
                optionsContainer.appendChild(btn);
            });

            document.getElementById('quiz-screen').style.display = 'block';
            
            timeLeft = 60; document.getElementById('timer-display').innerText = `⏱️ ${timeLeft}s`;
            clearInterval(timerInterval);
            timerInterval = setInterval(() => {
                timeLeft--; document.getElementById('timer-display').innerText = `⏱️ ${timeLeft}s`;
                if(timeLeft <= 0) {
                    clearInterval(timerInterval);
                    document.getElementById('quiz-feedback').innerText = "Time's up! Try again bestie! ⏰";
                    document.getElementById('quiz-feedback').style.display = 'block';
                    setTimeout(loadQuestion, 2000);
                }
            }, 1000);
        }

        function checkAnswer(selectedIndex) {
            if(selectedIndex === questions[currentQuestionIndex].answer) {
                clearInterval(timerInterval); handleCorrectAnswer();
            } else {
                document.getElementById('quiz-feedback').style.display = 'block';
                const qs = document.getElementById('quiz-screen');
                qs.classList.remove('shake'); void qs.offsetWidth; qs.classList.add('shake');
            }
        }

        function handleCorrectAnswer() {
            hideAll();
            if (currentQuestionIndex === 0) { // Bio
                playAudio(song1); document.getElementById('continue-popup').style.display = 'block';
            } else if (currentQuestionIndex === 1) { // Chem -> Video/GIF Screen
                document.getElementById('media-popup-screen').style.display = 'block';
            } else if (currentQuestionIndex === 2) { // Physics -> Image 1
                showImagePopup('your-image-1.jpg');
            } else if (currentQuestionIndex === 3) { // Math -> Image 2
                showImagePopup('your-image-2.jpg');
            } else if (currentQuestionIndex === 4) { // Final -> Image 3
                showImagePopup('your-image-3.jpg');
            }
        }

        function showImagePopup(imgSrc) {
            hideAll();
            document.getElementById('dynamic-image').src = imgSrc;
            document.getElementById('download-link').href = imgSrc;
            document.getElementById('image-popup-screen').style.display = 'block';
        }

        function handleImageContinue() {
            if(currentQuestionIndex < 4) {
                currentQuestionIndex++; loadQuestion();
            } else {
                hideAll(); document.getElementById('message-screen').style.display = 'block';
            }
        }

        function nextQuestion() { currentQuestionIndex++; loadQuestion(); }
        function showSocials() { hideAll(); document.getElementById('socials-screen').style.display = 'block'; }
        function showFinal() { hideAll(); document.getElementById('final-screen').style.display = 'block'; }
    </script>
</body>
</html>
